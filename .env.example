# Server
PORT=3000
NODE_ENV=production

# QBWC Auth
QBWC_USERNAME=bmb_voice_sync
QBWC_PASSWORD=your_secure_password_here
QBWC_COMPANY_FILE=

# REST API Auth
API_KEY=your_api_key_here

# Sync Settings
INVENTORY_SYNC_EVERY_N_CYCLES=1
CUSTOMER_SYNC_EVERY_N_CYCLES=5
QBXML_VERSION=16.0

# Webhooks (n8n endpoints)
WEBHOOK_ORDER_CREATED=https://n8n.targetdial.co/webhook/qb-order-created
WEBHOOK_INVOICE_CREATED=https://n8n.targetdial.co/webhook/qb-invoice-created
WEBHOOK_INVENTORY_UPDATED=https://n8n.targetdial.co/webhook/qb-inventory-updated
WEBHOOK_SYNC_ERROR=https://n8n.targetdial.co/webhook/qb-sync-error

# Logging
LOG_LEVEL=info
